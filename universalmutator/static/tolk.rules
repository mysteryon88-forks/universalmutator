# Tolk (TON) rules.
#
# Notes:
# - universal.rules already provides most operator/number mutations.
# - Here we keep Tolk-specific mutations anchored to documented syntax.

^\s*import\s ==> DO_NOT_MUTATE

/\* ==> SKIP_MUTATING_REST

true ==> false
false ==> true

# Comment replacement already covered by c_like.rules; add error replacement here.
(^\s*)(\S+[^{}]+.*)\n ==> \1throw 0xFFFF;\n

# Arithmetic assignment operator shuffle (muton AAOS).
\+= ==> -=
\+= ==> *=
\+= ==> /=
-= ==> +=
-= ==> *=
-= ==> /=
\*= ==> +=
\*= ==> -=
\*= ==> /=
/= ==> +=
/= ==> -=
/= ==> *=

# Bitwise assignment operator shuffle (muton BAOS).
\&= ==> |=
\&= ==> ^=
\|= ==> &=
\|= ==> ^=
\^= ==> &=
\^= ==> |=

# Shift assignment operator shuffle (muton SAOS).
<<= ==> >>=
>>= ==> <<=

# Shift operator shuffle (muton SOS).
<<(?!=) ==> >>
>>(?!=) ==> <<

# Bitwise operator shuffle with XOR (muton BOS).
([^\^])\^([^\^]) ==> \1&\2
([^\^])\^([^\^]) ==> \1|\2
([^&])&([^&]) ==> \1^\2
([^|])\|([^|]) ==> \1^\2

# Loop control swap (muton LC).
\bbreak\b ==> continue
\bcontinue\b ==> break

# While False (muton WF).
while (\(.*\)) ==> while (0==1)
while(\(.*\)) ==> while(0==1)

# Tolk unions support `is` / `!is` runtime checks.
(?<![!\w])is\b ==> !is
(?<!\w)!is\b ==> is

# Drop lazy loading and force eager evaluation.
(^|\s)lazy(\s+) ==> \1

# Remove getter exposure while keeping the function body.
\bget\s+fun\b ==> fun

# Mutate documented function/method attributes.
^(\s*)@inline\b ==> \1@noinline
^(\s*)@noinline\b ==> \1@inline
^(\s*)@inline_ref\b ==> \1@inline
^(\s*)@pure\b ==> \1
^(\s*)@method_id\s*\(\s*[^)\n]+\s*\) ==> \1@method_id(0)

# Strip mutability from instance receivers.
\bmutate\s+self\b ==> self
\bmutate\s+(?!self\b)([A-Za-z_]\w+)(\s*:) ==> \1\2

# Remove documented default parameter values from single-line function signatures.
(\bfun\s+[A-Za-z_][\w\.]*\s*\([^)\n]*\b[A-Za-z_]\w*\s*:\s*[^=,\)\n]*?\S)\s*=\s*[^,\)\n]+(,\s*[^)\n]*\)) ==> \1\2
(\bfun\s+[A-Za-z_][\w\.]*\s*\(\s*\b[A-Za-z_]\w*\s*:\s*[^=,\)\n]*?\S)\s*=\s*[^,\)\n]+(,\s*[^)\n]*\)) ==> \1\2
(\bfun\s+[A-Za-z_][\w\.]*\s*\([^)\n]*\b[A-Za-z_]\w*\s*:\s*[^=,\)\n]*?\S)\s*=\s*[^,\)\n]+(\s*\)) ==> \1\2

# Remove documented default field values from single-line struct declarations.
(^\s*[A-Za-z_]\w*\s*:\s*[A-Za-z_][A-Za-z0-9_<>\?\|\(\),\s]*?)\s*=\s*[^,\n]+(\s*(?://[^\n]*)?$) ==> \1\2

# Swap documented fixed-width signed/unsigned integer types.
\buint([1-9]\d?|1\d\d|2[0-4]\d|25[0-6])\b ==> int\1
\bint([1-9]\d?|1\d\d|2[0-4]\d|25[0-6])\b ==> uint\1

# Swap documented variable-width signed/unsigned integer families.
\bvaruint16\b ==> varint16
\bvarint16\b ==> varuint16
\bvaruint32\b ==> varint32
\bvarint32\b ==> varuint32

# Mutate explicit unsafe casts between signed/unsigned fixed-width integers.
\bas\s+uint([1-9]\d?|1\d\d|2[0-4]\d|25[0-6])\b ==> as int\1
\bas\s+int([1-9]\d?|1\d\d|2[0-4]\d|25[0-6])\b ==> as uint\1

# Mutate documented assert/throw and deserialization options.
(^\s*)assert\s*\((.+)\)\s*throw\s+([^;\n]+)(;?) ==> \1if (\2) throw \3\4
(\bthrowIfOpcodeDoesNotMatch\s*:\s*)[\w]+ ==> \g<1>63

# Relax documented non-null assertion.
([A-Za-z0-9_)\]])!(?=[\.,;\)\]\s]) ==> \1

# Swap closely related Tolk stdlib APIs documented in the FunC-to-Tolk mapping.
\bblockchain\.now\b ==> blockchain.logicalTime
\bblockchain\.logicalTime\b ==> blockchain.currentBlockLogicalTime
\bblockchain\.currentBlockLogicalTime\b ==> blockchain.logicalTime
\bcalculateSizeStrict\b ==> calculateSize
\bcalculateSize\b ==> calculateSizeStrict
\bcalculateForwardFeeWithoutLumpPrice\b ==> calculateForwardFee
\bcalculateForwardFee\b ==> calculateForwardFeeWithoutLumpPrice
\bcalculateGasFeeWithoutFlatPrice\b ==> calculateGasFee
\bcalculateGasFee\b ==> calculateGasFeeWithoutFlatPrice
\bacceptExternalMessage\b ==> commitContractDataAndActions
\bcommitContractDataAndActions\b ==> acceptExternalMessage
\brandom\.uint256\b ==> random.getSeed
\brandom\.getSeed\b ==> random.uint256

# Mutate documented stdlib parsing and serialization helpers.
\.loadRef\s*\( ==> .preloadRef(
\.preloadRef\s*\( ==> .loadRef(
\.loadInt\s*\( ==> .preloadInt(
\.preloadInt\s*\( ==> .loadInt(
\.loadUint\s*\( ==> .preloadUint(
\.preloadUint\s*\( ==> .loadUint(
\.loadBits\s*\( ==> .preloadBits(
\.preloadBits\s*\( ==> .loadBits(
\.loadDict\s*\( ==> .preloadDict(
\.preloadDict\s*\( ==> .loadDict(
\.loadMaybeRef\s*\( ==> .preloadMaybeRef(
\.preloadMaybeRef\s*\( ==> .loadMaybeRef(
\.loadInt\s*\( ==> .loadUint(
\.loadUint\s*\( ==> .loadInt(
\.preloadInt\s*\( ==> .preloadUint(
\.preloadUint\s*\( ==> .preloadInt(
\.storeInt\s*\( ==> .storeUint(
\.storeUint\s*\( ==> .storeInt(

# Mutate documented slice inspection helpers.
\.remainingBitsCount\s*\( ==> .remainingRefsCount(
\.remainingRefsCount\s*\( ==> .remainingBitsCount(
\.isEmpty\s*\( ==> .isEndOfBits(
\.isEmpty\s*\( ==> .isEndOfRefs(
\.isEndOfBits\s*\( ==> .isEmpty(
\.isEndOfRefs\s*\( ==> .isEmpty(
\.getFirstBits\s*\( ==> .getLastBits(
\.getLastBits\s*\( ==> .getFirstBits(

# Mutate documented address/message/payment helpers.
\.getStorageDuePayment\s*\( ==> .getStoragePaidPayment(
\.getStoragePaidPayment\s*\( ==> .getStorageDuePayment(
\.sendAndEstimateFee\s*\( ==> .estimateFeeWithoutSending(
\.estimateFeeWithoutSending\s*\( ==> .sendAndEstimateFee(
\.isInternal\s*\( ==> .isExternal(
\.isExternal\s*\( ==> .isInternal(
\.loadMessageOp\s*\( ==> .loadMessageQueryId(
\.loadMessageQueryId\s*\( ==> .loadMessageOp(
\.storeMessageOp\s*\( ==> .storeMessageQueryId(
\.storeMessageQueryId\s*\( ==> .storeMessageOp(

# Mutate documented low-level TVM dictionary helpers.
\.iDict(Get|Set|SetRef|SetIfNotExists|SetIfExists|GetRef|GetRefOrNull|Delete|SetAndGet|SetAndGetRefOrNull|DeleteAndGet|SetBuilder|SetBuilderIfNotExists|SetBuilderIfExists|DeleteFirstAndGet|DeleteLastAndGet|GetFirst|GetFirstAsRef|GetLast|GetLastAsRef|GetNext|GetNextOrEqual|GetPrev|GetPrevOrEqual)\s*\( ==> .uDict\1(
\.uDict(Get|Set|SetRef|SetIfNotExists|SetIfExists|GetRef|GetRefOrNull|Delete|SetAndGet|SetAndGetRefOrNull|DeleteAndGet|SetBuilder|SetBuilderIfNotExists|SetBuilderIfExists|DeleteFirstAndGet|DeleteLastAndGet|GetFirst|GetFirstAsRef|GetLast|GetLastAsRef|GetNext|GetNextOrEqual|GetPrev|GetPrevOrEqual)\s*\( ==> .iDict\1(
\.((?:i|u|s)Dict)GetFirst(AsRef)?\s*\( ==> .\g<1>GetLast\g<2>(
\.((?:i|u|s)Dict)GetLast(AsRef)?\s*\( ==> .\g<1>GetFirst\g<2>(
\.((?:i|u|s)Dict)DeleteFirstAndGet\s*\( ==> .\g<1>DeleteLastAndGet(
\.((?:i|u|s)Dict)DeleteLastAndGet\s*\( ==> .\g<1>DeleteFirstAndGet(
\.((?:i|u|s)Dict)GetNextOrEqual\s*\( ==> .\g<1>GetPrevOrEqual(
\.((?:i|u|s)Dict)GetPrevOrEqual\s*\( ==> .\g<1>GetNextOrEqual(
\.((?:i|u|s)Dict)GetNext\s*\( ==> .\g<1>GetPrev(
\.((?:i|u|s)Dict)GetPrev\s*\( ==> .\g<1>GetNext(

# Mutate documented compile-time string helpers.
\bstringCrc32\s*\( ==> stringCrc16(
\bstringCrc16\s*\( ==> stringCrc32(
\bstringSha256_32\s*\( ==> stringSha256(
\bstringSha256\s*\( ==> stringSha256_32(

# Mutate documented send mode constants used with stdlib messaging helpers.
\bSEND_MODE_REGULAR\b ==> SEND_MODE_CARRY_ALL_REMAINING_MESSAGE_VALUE
\bSEND_MODE_CARRY_ALL_REMAINING_MESSAGE_VALUE\b ==> SEND_MODE_REGULAR
\bSEND_MODE_CARRY_ALL_REMAINING_MESSAGE_VALUE\b ==> SEND_MODE_CARRY_ALL_BALANCE
\bSEND_MODE_CARRY_ALL_BALANCE\b ==> SEND_MODE_REGULAR
\bSEND_MODE_CARRY_ALL_BALANCE\b ==> SEND_MODE_CARRY_ALL_REMAINING_MESSAGE_VALUE
\bSEND_MODE_ESTIMATE_FEE_ONLY\b ==> 0
\bSEND_MODE_IGNORE_ERRORS\b ==> 0
\bSEND_MODE_PAY_FEES_SEPARATELY\b ==> 0
\bSEND_MODE_BOUNCE_ON_ACTION_FAIL\b ==> 0
\bSEND_MODE_DESTROY\b ==> 0
\bRESERVE_MODE_EXACT_AMOUNT\b ==> RESERVE_MODE_ALL_BUT_AMOUNT
\bRESERVE_MODE_ALL_BUT_AMOUNT\b ==> RESERVE_MODE_EXACT_AMOUNT
\bRESERVE_MODE_AT_MOST\b ==> RESERVE_MODE_EXACT_AMOUNT
\bRESERVE_MODE_EXACT_AMOUNT\b ==> RESERVE_MODE_AT_MOST
\bRESERVE_MODE_INCREASE_BY_ORIGINAL_BALANCE\b ==> 0
\bRESERVE_MODE_NEGATE_AMOUNT\b ==> 0
\bRESERVE_MODE_BOUNCE_ON_ACTION_FAIL\b ==> 0

# Mutate numeric send/reserve mode literals when passed directly to messaging helpers.
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>64\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b1\b([^;\n]*\)) ==> \g<1>0\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b2\b([^;\n]*\)) ==> \g<1>0\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b16\b([^;\n]*\)) ==> \g<1>0\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b32\b([^;\n]*\)) ==> \g<1>0\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b64\b([^;\n]*\)) ==> \g<1>0\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b64\b([^;\n]*\)) ==> \g<1>128\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b128\b([^;\n]*\)) ==> \g<1>0\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b128\b([^;\n]*\)) ==> \g<1>64\2
(\.\s*(?:send|sendAndEstimateFee|estimateFeeWithoutSending)\s*\(\s*[^;\n]*?)\b1024\b([^;\n]*\)) ==> \g<1>0\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>64\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b1\b([^;\n]*\)) ==> \g<1>0\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b2\b([^;\n]*\)) ==> \g<1>0\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b16\b([^;\n]*\)) ==> \g<1>0\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b32\b([^;\n]*\)) ==> \g<1>0\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b64\b([^;\n]*\)) ==> \g<1>0\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b64\b([^;\n]*\)) ==> \g<1>128\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b128\b([^;\n]*\)) ==> \g<1>0\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b128\b([^;\n]*\)) ==> \g<1>64\2
(\bsendRawMessage\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b1024\b([^;\n]*\)) ==> \g<1>0\2
(\breserveToncoinsOnBalance\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>1\2
(\breserveToncoinsOnBalance\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b2\b([^;\n]*\)) ==> \g<1>0\2
(\breserveToncoinsOnBalance\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>2\2
(\breserveToncoinsOnBalance\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b1\b([^;\n]*\)) ==> \g<1>0\2
(\breserveExtraCurrenciesOnBalance\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>1\2
(\breserveExtraCurrenciesOnBalance\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b2\b([^;\n]*\)) ==> \g<1>0\2
(\breserveExtraCurrenciesOnBalance\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>2\2
(\breserveExtraCurrenciesOnBalance\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b1\b([^;\n]*\)) ==> \g<1>0\2

# Mutate numeric message values in createMessage object literals.
(^\s*value:\s*)0(\s*,\s*(?://[^\n]*)?$) ==> \g<1>1\2
(^\s*value:\s*)([1-9]\d*)(\s*,\s*(?://[^\n]*)?$) ==> \g<1>0\3
(^\s*value:\s*)ton\s*\(\s*[^)\n]+\s*\)(\s*,\s*(?://[^\n]*)?$) ==> \g<1>0\2
(^\s*value:\s*)([A-Za-z_]\w*(?:\.[A-Za-z_]\w*)*\s*\([^()\n]*\))(\s*,\s*(?://[^\n]*)?$) ==> \g<1>0\3
(^\s*value:\s*)(?!0\b)(?![1-9]\d*\b)(?!ton\s*\()([^,\n]+?)(\s*,\s*(?://[^\n]*)?$) ==> \g<1>0\3

# Flip documented bounce modes used when sending messages.
\bBounceMode\.NoBounce\b ==> BounceMode.RichBounce
\bBounceMode\.Only256BitsOfBody\b ==> BounceMode.RichBounce
\bBounceMode\.RichBounceOnlyRootCell\b ==> BounceMode.RichBounce

# Mutate numeric message opcodes/prefixes declared on struct headers.
(^\s*struct\s+\()(?:0x[0-9A-Fa-f]+|0b[01]+)(\)\s+[A-Za-z_]\w*) ==> \g<1>0x00000000\2
(^\s*struct\s+\()(?:0x[0-9A-Fa-f]+|0b[01]+)(\)\s+[A-Za-z_]\w*) ==> \g<1>0xFFFFFFFF\2
