# Tact (TON) rules.
#
# Notes:
# - universal.rules already provides most operator/number mutations.
# - Here we mainly add comment skipping and a few Tact-specific flips.

^\s*import\s ==> DO_NOT_MUTATE

/// ==> SKIP_MUTATING_REST
/\* ==> SKIP_MUTATING_REST

# Error replacement (muton ER).
(^\s*)(\S+[^{}]+.*)\n ==> \1throw(0);\n

true ==> false
false ==> true

# Arithmetic assignment operator shuffle (muton AAOS).
\+= ==> -=
\+= ==> *=
\+= ==> /=
-= ==> +=
-= ==> *=
-= ==> /=
\*= ==> +=
\*= ==> -=
\*= ==> /=
/= ==> +=
/= ==> -=
/= ==> *=

# Bitwise assignment operator shuffle (muton BAOS).
\&= ==> |=
\&= ==> ^=
\|= ==> &=
\|= ==> ^=
\^= ==> &=
\^= ==> |=

# Shift assignment operator shuffle (muton SAOS).
<<= ==> >>=
>>= ==> <<=

# Shift operator shuffle (muton SOS).
<<(?!=) ==> >>
>>(?!=) ==> <<

# Bitwise operator shuffle with XOR (muton BOS).
([^\^])\^([^\^]) ==> \1&\2
([^\^])\^([^\^]) ==> \1|\2
([^&])&([^&]) ==> \1^\2
([^|])\|([^|]) ==> \1^\2

# While False (muton WF).
while (\(.*\)) ==> while (0==1)
while(\(.*\)) ==> while(0==1)

# Until False (muton UF).
until (\(.*\)) ==> until (0==1)
until(\(.*\)) ==> until(0==1)

# Repeat Zero (muton RZ).
repeat (\(.*\)) ==> repeat (0)
repeat(\(.*\)) ==> repeat(0)

# Ternary True/False (muton TT/TF).
(^\s*)([^\?\n]+)\?([^:\n]+):([^\n]+) ==> \1false ? \3 : \4
(^\s*)([^\?\n]+)\?([^:\n]+):([^\n]+) ==> \1true ? \3 : \4

# Loop control swap (muton LC).
\bbreak\b ==> continue
\bcontinue\b ==> break

throwIf ==> throwUnless
throwUnless ==> throwIf
