# FunC (TON) rules.

^\s*#include\s ==> DO_NOT_MUTATE

;; ==> SKIP_MUTATING_REST

throw_if ==> throw_unless
throw_unless ==> throw_if
throw_arg_if ==> throw_arg_unless
throw_arg_unless ==> throw_arg_if
THROW_IF ==> THROW_UNLESS
THROW_UNLESS ==> THROW_IF

# Comment replacement (muton CR).
(^\s*)(\S+[^{}]+.*)\n ==> \1;; \2\n

# Error replacement (muton ER).
(^\s*)(\S+[^{}]+.*)\n ==> \1throw(0);\n

# Boolean literal flip (muton BL).
true ==> false
false ==> true

# Arithmetic assignment operator shuffle (muton AAOS).
\+= ==> -=
\+= ==> *=
\+= ==> /=
-= ==> +=
-= ==> *=
-= ==> /=
\*= ==> +=
\*= ==> -=
\*= ==> /=
/= ==> +=
/= ==> -=
/= ==> *=

# Bitwise assignment operator shuffle (muton BAOS).
\&= ==> |=
\&= ==> ^=
\|= ==> &=
\|= ==> ^=
\^= ==> &=
\^= ==> |=

# Shift assignment operator shuffle (muton SAOS).
<<= ==> >>=
>>= ==> <<=

# Shift operator shuffle (muton SOS).
<<(?!=) ==> >>
>>(?!=) ==> <<

# Bitwise operator shuffle with XOR (muton BOS).
([^\^])\^([^\^]) ==> \1&\2
([^\^])\^([^\^]) ==> \1|\2
([^&])&([^&]) ==> \1^\2
([^|])\|([^|]) ==> \1^\2

# Division assignment operator shuffle (muton DAOS).
(?<![~^])/= ==> ~/=
(?<![~^])/= ==> ^/=
~/= ==> /=
~/= ==> ^/=
\^/= ==> /=
\^/= ==> ~/=

# Division operator shuffle (muton DOS).
([^*/~^])/([^*/]) ==> \1~/\2
([^*/~^])/([^*/]) ==> \1^/\2
~/(?![=]) ==> /
~/(?![=]) ==> ^/
\^/(?![=]) ==> /
\^/(?![=]) ==> ~/

# Modulo assignment operator shuffle (muton MAOS).
(?<![~^])%= ==> ~%=
(?<![~^])%= ==> ^%=
~%= ==> %=
~%= ==> ^%=
\^%= ==> %=
\^%= ==> ~%=

# Modulo operator shuffle (muton MOS).
(?<![~^])%(?![=]) ==> ~%
(?<![~^])%(?![=]) ==> ^%
~%(?![=]) ==> %
~%(?![=]) ==> ^%
\^%(?![=]) ==> %
\^%(?![=]) ==> ~%

# If Not False/True (muton INF/INT).
ifnot (\(.*\)) ==> ifnot (0==1)
ifnot(\(.*\)) ==> ifnot(0==1)
ifnot (\(.*\)) ==> ifnot (1==1)
ifnot(\(.*\)) ==> ifnot(1==1)

# While False (muton WF).
while (\(.*\)) ==> while (0==1)
while(\(.*\)) ==> while(0==1)

# Until False (muton UF).
until (\(.*\)) ==> until (0==1)
until(\(.*\)) ==> until(0==1)

# Repeat Zero (muton RZ).
repeat (\(.*\)) ==> repeat (0)
repeat(\(.*\)) ==> repeat(0)

# Loop control swap (muton LC).
\bbreak\b ==> continue
\bcontinue\b ==> break

# Mutate documented function specifiers.
\binline_ref\b ==> inline
\binline\b ==> inline_ref
\binline_ref\b ==> 
\binline\b ==> 
\bimpure\b ==> 
\bmethod_id\s*\(\s*[^)\n]+\s*\) ==> method_id(0)
\bmethod_id\b(?!\s*\() ==> method_id(0)

# Mutate documented gas/state management helpers.
(^\s*)accept_message\s*\(\s*\)\s*; ==> \1;
(^\s*)commit\s*\(\s*\)\s*; ==> \1;
(^\s*)set_code\s*\(\s*[^;\n]+\)\s*; ==> \1;

# Mutate documented time/random helpers.
\bnow\s*\( ==> cur_lt(
\bcur_lt\s*\( ==> block_lt(
\bblock_lt\s*\( ==> cur_lt(
\brandom\s*\( ==> get_seed(
\bget_seed\s*\( ==> random(

# Mutate documented slice/cell load helpers.
\bload_ref\s*\( ==> preload_ref(
\bpreload_ref\s*\( ==> load_ref(
\bload_dict\s*\( ==> preload_dict(
\bpreload_dict\s*\( ==> load_dict(
\bload_maybe_ref\s*\( ==> preload_maybe_ref(
\bpreload_maybe_ref\s*\( ==> load_maybe_ref(
\bload_int\s*\( ==> preload_int(
\bpreload_int\s*\( ==> load_int(
\bload_uint\s*\( ==> preload_uint(
\bpreload_uint\s*\( ==> load_uint(
\bload_bits\s*\( ==> preload_bits(
\bpreload_bits\s*\( ==> load_bits(

# Mutate documented integer load/store helpers.
\bload_uint\b ==> load_int
\bload_int\b ==> load_uint
\bstore_uint\b ==> store_int
\bstore_int\b ==> store_uint

# Store coins/int/uint as zero (muton SC/SI/SU).
(\.store_coins\s*\()\s*[^,\)]+ ==> \g<1>0
(\.store_grams\s*\()\s*[^,\)]+ ==> \g<1>0
(\.store_uint\s*\()\s*[^,\)]+ ==> \g<1>0
(\.store_int\s*\()\s*[^,\)]+ ==> \g<1>0
(\bstore_coins\s*\(\s*[^,]+,\s*)[^,\)]+ ==> \g<1>0
(\bstore_grams\s*\(\s*[^,]+,\s*)[^,\)]+ ==> \g<1>0
(\bstore_uint\s*\(\s*[^,]+,\s*)[^,]+ ==> \g<1>0
(\bstore_int\s*\(\s*[^,]+,\s*)[^,]+ ==> \g<1>0

# Swap modifying vs non-modifying call notation for numeric built-ins.
(\b[A-Za-z_]\w*)\.load_int\s*\( ==> \1~load_int(
(\b[A-Za-z_]\w*)~load_int\s*\( ==> \1.load_int(
(\b[A-Za-z_]\w*)\.load_uint\s*\( ==> \1~load_uint(
(\b[A-Za-z_]\w*)~load_uint\s*\( ==> \1.load_uint(
(\b[A-Za-z_]\w*)\.load_bits\s*\( ==> \1~load_bits(
(\b[A-Za-z_]\w*)~load_bits\s*\( ==> \1.load_bits(
(\b[A-Za-z_]\w*)\.store_int\s*\( ==> \1~store_int(
(\b[A-Za-z_]\w*)~store_int\s*\( ==> \1.store_int(
(\b[A-Za-z_]\w*)\.store_uint\s*\( ==> \1~store_uint(
(\b[A-Za-z_]\w*)~store_uint\s*\( ==> \1.store_uint(

# Mutate documented slice/builder inspection helpers.
\bslice_refs\s*\( ==> slice_bits(
\bslice_bits\s*\( ==> slice_refs(
\bbuilder_refs\s*\( ==> builder_bits(
\bbuilder_bits\s*\( ==> builder_refs(
\bslice_empty\?\s*\( ==> slice_refs_empty?(
\bslice_refs_empty\?\s*\( ==> slice_empty?(
\bslice_empty\?\s*\( ==> slice_data_empty?(
\bslice_data_empty\?\s*\( ==> slice_empty?(
\bslice_refs_empty\?\s*\( ==> slice_data_empty?(
\bslice_data_empty\?\s*\( ==> slice_refs_empty?(

# Swap signed/unsigned dictionary helpers.
\bidict_([A-Za-z0-9_]+\??)(?=[^A-Za-z0-9_]|$) ==> udict_\1
\budict_([A-Za-z0-9_]+\??)(?=[^A-Za-z0-9_]|$) ==> idict_\1

# Swap closely related built-ins with non-symbolic names.
\bdivmod\b ==> moddiv
\bmoddiv\b ==> divmod
(?<![A-Za-z0-9_])~divmod\b ==> ~moddiv
(?<![A-Za-z0-9_])~moddiv\b ==> ~divmod
\bmuldiv\b ==> muldivr
\bmuldivr\b ==> muldivc
\bmuldivc\b ==> muldiv
\bmuldivmod\b ==> divmod
\bint_at\s*\( ==> cell_at(
\bcell_at\s*\( ==> slice_at(
\bslice_at\s*\( ==> tuple_at(
\btuple_at\s*\( ==> int_at(
\bat\s*\( ==> tuple_at(

# Mutate numeric send/reserve mode literals when passed directly to stdlib helpers.
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>1\2
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b1\b([^;\n]*\)) ==> \g<1>0\2
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b2\b([^;\n]*\)) ==> \g<1>0\2
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b16\b([^;\n]*\)) ==> \g<1>0\2
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b32\b([^;\n]*\)) ==> \g<1>0\2
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b64\b([^;\n]*\)) ==> \g<1>128\2
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b128\b([^;\n]*\)) ==> \g<1>64\2
(\bsend_raw_message\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b1024\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>1\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b1\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b2\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b16\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b32\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b64\b([^;\n]*\)) ==> \g<1>128\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b128\b([^;\n]*\)) ==> \g<1>64\2
(\braw_reserve\s*\(\s*[^,;\n]+,\s*[^;\n]*?)\b1024\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b0\b([^;\n]*\)) ==> \g<1>1\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b1\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b2\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b16\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b32\b([^;\n]*\)) ==> \g<1>0\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b64\b([^;\n]*\)) ==> \g<1>128\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b128\b([^;\n]*\)) ==> \g<1>64\2
(\braw_reserve_extra\s*\(\s*[^,;\n]+,\s*[^,;\n]+,\s*[^;\n]*?)\b1024\b([^;\n]*\)) ==> \g<1>0\2
