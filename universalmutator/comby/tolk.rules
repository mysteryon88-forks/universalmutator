:[lhs]|:[rhs] ==> :[lhs]^:[rhs]
:[lhs] is :[rhs] ==> :[lhs] !is :[rhs]
:[lhs] !is :[rhs] ==> :[lhs] is :[rhs]

lazy :[rest] ==> :[rest]
