# Shared TON comby mutations used by Tact, FunC, and Tolk by default.
#
# These mirror the conservative common regex families from static/ton_common.rules.

true ==> false
false ==> true

:[lhs] == :[rhs] ==> :[lhs] != :[rhs]
:[lhs] != :[rhs] ==> :[lhs] == :[rhs]
:[lhs] <= :[rhs] ==> :[lhs] < :[rhs]
:[lhs] <= :[rhs] ==> :[lhs] == :[rhs]
:[lhs] >= :[rhs] ==> :[lhs] > :[rhs]
:[lhs] >= :[rhs] ==> :[lhs] == :[rhs]

:[lhs] && :[rhs] ==> :[lhs] || :[rhs]
:[lhs] || :[rhs] ==> :[lhs] && :[rhs]

while (:[cond]) ==> while (false)
while(:[cond]) ==> while(false)

break; ==> continue;
continue; ==> break;

:[lhs]+=:[rhs] ==> :[lhs]-=:[rhs]
:[lhs]+=:[rhs] ==> :[lhs]*=:[rhs]
:[lhs]+=:[rhs] ==> :[lhs]/=:[rhs]
:[lhs]-=:[rhs] ==> :[lhs]+=:[rhs]
:[lhs]-=:[rhs] ==> :[lhs]*=:[rhs]
:[lhs]-=:[rhs] ==> :[lhs]/=:[rhs]
:[lhs]*=:[rhs] ==> :[lhs]+=:[rhs]
:[lhs]*=:[rhs] ==> :[lhs]-=:[rhs]
:[lhs]*=:[rhs] ==> :[lhs]/=:[rhs]
:[lhs~.*[^~^]\s*]/=:[rhs] ==> :[lhs]+=:[rhs]
:[lhs~.*[^~^]\s*]/=:[rhs] ==> :[lhs]-=:[rhs]
:[lhs~.*[^~^]\s*]/=:[rhs] ==> :[lhs]*=:[rhs]

:[lhs]&=:[rhs] ==> :[lhs]|=:[rhs]
:[lhs]&=:[rhs] ==> :[lhs]^=:[rhs]
:[lhs]|=:[rhs] ==> :[lhs]&=:[rhs]
:[lhs]|=:[rhs] ==> :[lhs]^=:[rhs]
:[lhs]^=:[rhs] ==> :[lhs]&=:[rhs]
:[lhs]^=:[rhs] ==> :[lhs]|=:[rhs]

:[lhs]<<=:[rhs] ==> :[lhs]>>=:[rhs]
:[lhs]>>=:[rhs] ==> :[lhs]<<=:[rhs]
:[lhs]<<:[rhs] ==> :[lhs]>>:[rhs]
:[lhs]>>:[rhs] ==> :[lhs]<<:[rhs]
