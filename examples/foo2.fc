;; Focused FunC probe for rules that produced INVALID mutants in foo.fc.
#include "tolk-bench/contracts_FunC/01_jetton/stdlib.fc";

const marker_throw_if = 1;
const marker_throw_unless = 2;

() foo2_noop() inline {
}

(int) foo2_method_explicit() impure method_id(10) {
    return 10;
}

(int) foo2_method_bare() method_id {
    return 11;
}

cell foo2_cell() inline_ref {
    cell child = begin_cell().store_uint(7, 8).end_cell();
    return begin_cell()
        .store_uint(0xAB, 8)
        .store_int(-5, 8)
        .store_ref(child)
        .store_uint(0xCC, 8)
        .end_cell();
}

int foo2_operators(int a, int b) impure {
    a /= 2;
    a ~/= 2;
    b ^/= 2;

    int plain_xor = a ^ b;
    int ceil_div = b ^/ 2;
    b ^%= 2;
    int ceil_mod = b ^% 2;

    if (a > b) {
        a += 1;
    }
    ifnot (a == b) {
        b += 1;
    }
    int steps = 0;
    while (steps < 2) {
        steps += 1;
    }
    do {
        steps -= 1;
    } until (steps == 0);

    return a + b + plain_xor + ceil_div + ceil_mod;
}

() foo2_loads(cell source) impure {
    slice s1 = source.begin_parse();
    slice s2 = source.begin_parse();
    slice s3 = source.begin_parse();
    slice s4 = source.begin_parse();
    slice s5 = source.begin_parse();
    slice s6 = source.begin_parse();

    var global_i = load_int(s1, 8);
    var global_u = load_uint(s2, 8);
    var global_bits = load_bits(s3, 8);
    int modifying_i = s4~load_int(8);
    int modifying_u = s5~load_uint(8);
    slice modifying_bits = s6~load_bits(8);

    var both = muldivmod(10, 2, 3);
    throw_if(40, modifying_i == modifying_u);
    throw_unless(41, modifying_i + modifying_u >= 0);
}

() main() impure {
    cell sample = foo2_cell();
    int score = foo2_method_explicit() + foo2_method_bare();
    int changed = foo2_operators(score, marker_throw_if + marker_throw_unless);
    foo2_loads(sample);
    throw_if(42, changed == 0);
    throw_unless(43, changed != 0);
}
